# 약사로 케어 환경변수 예시 — 실제 값은 .env.local 에 넣고, 이 파일에는 값을 적지 않는다.
# (.env.local 은 git 에 올라가지 않음 / .env.example 은 올라가므로 절대 실제 키 금지)

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 식약처 공공 API (data.go.kr) — 공통 키
MFDS_EASY_DRUG_KEY=
MFDS_DRUG_LICENSE_KEY=
MFDS_DUR_ITEM_KEY=
MFDS_DUR_INGREDIENT_KEY=
MFDS_HEALTH_FOOD_KEY=
MFDS_HEALTH_FOOD_INDIVIDUAL_KEY=

# OpenAI (처방전 파싱 보조)
OPENAI_API_KEY=

# 네이버 CLOVA OCR — 콘솔: https://console.ncloud.com/ocr/domain
CLOVA_OCR_API_URL=
CLOVA_OCR_SECRET=

NEXT_PUBLIC_SHOW_INTERACTIONS=false

# 심평원 약국현황 API (건강보험심사평가원_약국정보서비스)
HIRA_PHARMACY_KEY=

# Web Push (VAPID) — 복약 알림 푸시
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
CRON_SECRET=

# Anthropic — PubMed 근거 한국어 요약(claude-sonnet-4-6). /api/evidence 에서 사용.
# 발급: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# NCBI E-utilities (선택) — 넣으면 PubMed rate limit 3→10 req/s. 없어도 동작.
# 발급: https://www.ncbi.nlm.nih.gov/account → Settings → API Key Management
NCBI_API_KEY=

# MedData (건기식·식품-약물 상호작용)
MEDDATA_API_KEY=

# 식품안전나라 (건기식 정보)
FOODSAFETY_API_KEY=
